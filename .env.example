# Required: Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Required: same token used to protect FastAPI poster routes
API_TOKEN=change_this_secret_api_token

# Bot will call this FastAPI base URL. For run_all.py keep localhost.
API_BASE_URL=http://127.0.0.1:8000

# Optional for run_all.py FastAPI server
API_HOST=127.0.0.1
API_PORT=8000

# Optional: JioHotstar personal account token (x-hs-usertoken).
# Only needed if the free/basic metadata lookup misses content for you.
# NEVER share this value or commit it - it is tied to your personal account.
HOTSTAR_USER_TOKEN=
